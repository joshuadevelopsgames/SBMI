# AWS / production: provide via Secrets Manager or deployment environment.
# Do not commit .env with real values.

# PostgreSQL. Local (Docker): use below. AWS: use sslmode=require.
# Supabase (Vercel): use Connection pooling → Transaction (port 6543) with ?pgbouncer=true&sslmode=require.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/sbmi"
# DATABASE_URL="postgresql://user:password@your-rds-endpoint:5432/sbmi?sslmode=require"
# DATABASE_URL="postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Session cookie signing. Generate: openssl rand -hex 32
# SESSION_SECRET="..."

# App URL (for password reset / 2FA links). Set in deployment.
# NEXT_PUBLIC_APP_URL="https://your-app.run.app or https://your-domain.com"

# Footer mailto (member shell + public shell). Defaults to info@sbmi.ca if unset.
# NEXT_PUBLIC_SUPPORT_EMAIL="support@your-domain.com"

# Demo mode: show "Enter as member" / "Enter as admin" on login and allow instant sign-in without password.
# DEMO_MODE="true"

# Email (2FA and password reset). Optional: Resend API key.
# RESEND_API_KEY="..."
# EMAIL_FROM="SBMI Portal <noreply@your-domain.com>"

# reCAPTCHA v2 (checkbox) — forgot-password gate (US13). Required in production.
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY="..."
# RECAPTCHA_SECRET_KEY="..."

# Stripe (Phase 1c). Publishable key is exposed to the browser; secret stays server-only.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."
# STRIPE_SECRET_KEY="sk_..."

# Vercel Cron: authorize GET /api/cron/reminders (Bearer or ?secret=)
# CRON_SECRET="..."

# Optional: Framer API key (for programmatic access to Framer site/layout when needed).
# FRAMER_API_KEY="..."
