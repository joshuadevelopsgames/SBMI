// SBMI Member Portal - PostgreSQL (AWS RDS/Aurora)
// DATABASE_URL must be set (e.g. from Secrets Manager in production).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id   String @id @default(cuid())
  name String @unique // MEMBER | ADMIN
  users User[]
}

model User {
  id                    String    @id @default(cuid())
  email                 String?   // Plain email for 2FA and password reset (SOW: may be stored in plain text)
  emailHash             String    @unique
  passwordHash          String
  roleId                String
  role                  Role      @relation(fields: [roleId], references: [id])
  memberId              String?   @unique
  member                Member?   @relation(fields: [memberId], references: [id])
  lastSuccessfulLoginAt DateTime?
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  twoFactorCodes        TwoFactorCode[]
  emailChangeRequests   EmailChangeRequest[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  isPre2FA   Boolean  @default(false) // true = passed password, awaiting 2FA (admin only)
  createdAt  DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model EmailChangeRequest {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TwoFactorCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Household {
  id        String   @id @default(cuid())
  name      String?
  address   String?
  city      String   @default("Calgary")
  members   Member[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id              String         @id @default(cuid())
  memberNumber    String?        @unique
  firstName       String
  lastName        String
  phone           String?
  householdId     String
  household       Household     @relation(fields: [householdId], references: [id])
  user            User?
  status          String         @default("PENDING") // PENDING | ACTIVE | SUSPENDED | TERMINATED
  paymentSchedule String        @default("MONTHLY") // MONTHLY | WEEKLY | BIWEEKLY
  joinedAt        DateTime?     @default(now()) // SOW: membership start date for duration display
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payments           Payment[]
  claims             Claim[]
  familyMembers     FamilyMember[]
  assistanceRequests AssistanceRequest[]
}

model Payment {
  id               String   @id @default(cuid())
  memberId         String
  member           Member   @relation(fields: [memberId], references: [id])
  amount           Float
  category         String   // DUES | FEE | PENALTY | ADMISSION
  status           String   @default("PENDING") // PENDING | COMPLETED | FAILED
  stripePaymentId  String?
  receiptUrl       String?  // SOW US5: stored with amount and paidAt, associated with member
  dueAt            DateTime?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// SOW Family Management: family members associated with member account (Article 2.5)
model FamilyMember {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fullName  String
  birthDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
}

model Claim {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  reason      String   // e.g. FUNERAL | ILLNESS | CATASTROPHE
  amount      Float?
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | PAID
  description String?
  approvedById String?
  approvedAt   DateTime?
  rejectionReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// SOW US51: assistance request; no status/resolution/history shown to member
model AssistanceRequest {
  id             String   @id @default(cuid())
  memberId       String
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  requestType    String   // SELF | OTHER
  familyMemberId String?
  otherName      String?
  otherPhone     String?
  description    String
  createdAt      DateTime @default(now())

  @@index([memberId])
}

model Application {
  id               String    @id @default(cuid())
  fullName         String
  email            String
  phone            String
  householdSize    String?
  message          String?
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason  String?
  processedAt      DateTime?
  processedById    String?
  createdMemberId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String   // MEMBER | PAYMENT | CLAIM | USER | APPLICATION
  entityId  String?
  details   String?  // JSON or summary
  createdAt DateTime @default(now())
}
