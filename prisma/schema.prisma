// SBMI Member Portal - PostgreSQL (AWS RDS/Aurora)
// DATABASE_URL must be set (e.g. from Secrets Manager in production).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id   String @id @default(cuid())
  name String @unique // MEMBER | ADMIN
  users User[]
}

model User {
  id                    String    @id @default(cuid())
  email                 String?   // Plain email for 2FA and password reset (SOW: may be stored in plain text)
  emailHash             String    @unique
  passwordHash          String
  roleId                String
  role                  Role      @relation(fields: [roleId], references: [id])
  memberId              String?   @unique
  member                Member?   @relation(fields: [memberId], references: [id])
  lastSuccessfulLoginAt DateTime?
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  twoFactorCodes        TwoFactorCode[]
  emailChangeRequests   EmailChangeRequest[]
  profileChangeRequests ProfileChangeRequest[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  isPre2FA   Boolean  @default(false) // true = passed password, awaiting 2FA (admin only)
  createdAt  DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model EmailChangeRequest {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail  String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TwoFactorCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Household {
  id        String   @id @default(cuid())
  name      String?
  address   String?
  city      String   @default("Calgary")
  members   Member[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Member {
  id              String         @id @default(cuid())
  memberNumber    String?        @unique
  firstName       String
  lastName        String
  phone           String?
  householdId     String
  household       Household     @relation(fields: [householdId], references: [id])
  user            User?
  status                String  @default("PENDING") // PENDING | PENDING_REGISTRATION | ACTIVE | SUSPENDED | TERMINATED
  paymentSchedule       String  @default("MONTHLY") // MONTHLY | WEEKLY | BIWEEKLY
  membershipCategoryCode String? // From application (US4); fees table Phase 1c+
  joinedAt        DateTime?     @default(now()) // SOW: membership start date for duration display
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payments           Payment[]
  claims             Claim[]
  familyMembers     FamilyMember[]
  assistanceRequests AssistanceRequest[]
}

model Payment {
  id               String   @id @default(cuid())
  memberId         String
  member           Member   @relation(fields: [memberId], references: [id])
  amount           Float
  category         String   // DUES | FEE | PENALTY | ADMISSION
  status           String   @default("PENDING") // PENDING | COMPLETED | FAILED
  method           String   @default("CARD")    // CARD | BANK | CASH | CHEQUE | ETRANSFER
  cardBrand        String?  // VISA | MASTERCARD | AMEX | DISCOVER (for display)
  cardLast4        String?  // Last 4 digits for display only
  stripePaymentId  String?
  receiptUrl       String?  // SOW US46: stored with amount and paidAt, associated with member
  dueAt            DateTime?
  paidAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// SOW Family Management (US27, US28, US87): all Add/Edit/Delete require Executive Committee approval.
// `status` tracks the underlying record state. `pendingChange*` fields hold a proposed edit awaiting EC review;
// once approved, they're applied to the canonical fields and cleared. `pendingDeletion` marks a delete request.
model FamilyMember {
  id              String    @id @default(cuid())
  memberId        String
  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  fullName        String
  birthDate       DateTime
  relationship    String?   // Spouse | Child | Parent | Sibling | Other (US28)
  maritalStatus   String    @default("UNMARRIED") // UNMARRIED | MARRIED (US28)
  status          String    @default("PENDING_APPROVAL") // PENDING_APPROVAL | APPROVED | REJECTED (US27)
  // Edit-request fields: when a member submits an edit, the new values land here until EC approves
  pendingFullName       String?
  pendingBirthDate      DateTime?
  pendingRelationship   String?
  pendingMaritalStatus  String?
  pendingDeletion       Boolean   @default(false) // US31: flagged on delete request
  decidedAt             DateTime?
  decidedById           String?
  rejectionReason       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([memberId])
  @@index([status])
}

// SOW US55: first/last name changes require Executive Committee approval workflow.
// Email changes have their own EmailChangeRequest model (US57/US58); name changes use this one.
model ProfileChangeRequest {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldName     String    // firstName | lastName
  oldValue      String
  newValue      String
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED
  decidedAt     DateTime?
  decidedById   String?
  rejectionReason String?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([status])
}

model Claim {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  reason      String   // e.g. FUNERAL | ILLNESS | CATASTROPHE
  amount      Float?
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | PAID
  description String?
  approvedById String?
  approvedAt   DateTime?
  rejectionReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// SOW US51: assistance request; no status/resolution/history shown to member
model AssistanceRequest {
  id             String   @id @default(cuid())
  memberId       String
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  requestType    String   // SELF | OTHER
  familyMemberId String?
  otherName      String?
  otherPhone     String?
  description    String
  createdAt      DateTime @default(now())

  @@index([memberId])
}

model Application {
  id               String    @id @default(cuid())
  fullName         String
  email            String
  phone            String
  address          String? // US4: mailing / residency line
  householdSize    String?
  proposedCategory String? // US4: MembershipCategory code (see membership-categories.ts)
  message          String?
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason  String?
  processedAt      DateTime?
  processedById    String?
  createdMemberId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String   // MEMBER | PAYMENT | CLAIM | USER | APPLICATION
  entityId  String?
  details   String?  // JSON or summary
  createdAt DateTime @default(now())
}
